
{{< partials/layout }}
  {{$ title }}{{ app.name }} • {{ page.title }}{{/ title }}

  {{$ content }}
    <h1>{{ event.name }} - {{ page.heading }}</h1>

    <p>Results for {{ event.name }} at {{ event.circuit }} on {{ event.display_date }}.</p>

    <table>
      <thead>
        <tr>
          <th>Place</th>
          <th>Rider</th>
        </tr>
      </thead>
      <tbody>
    {{# results }}
        <tr>
          <td>{{ position }}</td>
          <td>{{ rider_name }}</td>
        </tr>
    {{/ results }}
      </tbody>
    </table>
  <p><a href="https://www.motogp.com/en/world-standing/2026/motogp/championship-standings" target="_blank">Results and standings</a> for the MotoGP 2026 season from the <a href="https://www.motogp.com/en" target="_blank">official site.</a></p>
  {{/ content }}
{{/ partials/layout }}
