
{{< partials/layout }}
  {{$ title }}{{ app.name }} • {{ page.title }}{{/ title }}
  {{$ content }}
    <h2>{{ page.heading }}</h2>

    <table>
      <thead>
        <tr>
          <th>Rider Name</th>
        </tr>
      </thead>
      <tbody>
    {{# riders }}
        <tr>
          <td>{{ name }}</td>
        </tr>
    {{/ riders }}
      </tbody>
    </table>

  {{/ content }}
{{/ partials/layout }}
