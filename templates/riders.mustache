{{< partials/layout }}
  {{$ title }}{{ app.name }} • {{ page.title }}{{/ title }}

  {{$ content }}
    <h1>{{ page.heading }}</h1>

    <table>
      <thead>
        <tr>
          <th>Rider Name</th>
          {{# user.admin }}<th>Admin</th> {{/ user.admin }}
        </tr>
      </thead>
      <tbody>
      {{# riders }}
        <tr>
          <td>{{ name }}</td>
          {{# user.admin }}
          <td><a href="rider.php?rider_id={{ rider_id }}"><button>Edit</button></a></td>
          {{/ user.admin }}
        </tr>
      {{/ riders }}
      </tbody>
    </table>

  {{/ content }}
{{/ partials/layout }}
